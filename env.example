# ============================================
# TechaNewz Frontend - Environment Variables
# ============================================
#
# Copy this file to .env and update with your values:
#   cp env.example .env
#

# ============================================
# API Configuration
# ============================================

# Backend API base URL (no trailing slash)
# Dev: http://localhost:5005
# Prod: https://api.techshup.dimssu.com
VITE_API_BASE_URL=http://localhost:5005

# Mudra auth microservice base URL
# Dev: http://localhost:3001
# Prod: https://mudra-app.dimssu.com
VITE_MUDRA_BASE_URL=http://localhost:3001

# ============================================
# Firebase (web Google Sign-In)
# ============================================
# From Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=oauth-f6bd6.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=oauth-f6bd6

# Optional: web OAuth client ID — only needed if you wire it into a custom flow.
# The mobile app reads this from google-services.json instead.
# VITE_GOOGLE_WEB_CLIENT_ID=

# ============================================
# Observability (optional)
# ============================================
# Leave unset to disable. When set, errors and traces are sent.
# VITE_SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX
# VITE_GA_ID=G-XXXXXXXXXX

# ============================================
# Notes:
# ============================================
# - All VITE_* variables are exposed to the client (do not put secrets here)
# - Never commit .env file to version control
# - Use .env.local for local overrides (gitignored)
# - For production, set these in Vercel project settings
